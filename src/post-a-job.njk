  <section class="post-job-footer" aria-labelledby="what-happens-next">
    <div>
      <p class="post-job-eyebrow">Simple from here</p>
      <h2 id="what-happens-next">What happens next?</h2>
    </div>
    <ol>
      <li><span>1</span><div><strong>Choose your package</strong><p>Select the reach that works for your role.</p></div></li>
      <li><span>2</span><div><strong>Send us the details</strong><p>We’ll collect your job description, application link, and brand assets.</p></div></li>
      <li><span>3</span><div><strong>Go live</strong><p>We’ll review the listing and coordinate your launch.</p></div></li>
    </ol>
  </section>

  <p class="post-job-contact">Have a question or need a custom hiring campaign? <a href="mailto:{{ site.email }}">Email us</a>.</p>
</section>
