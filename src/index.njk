---
layout: layouts/base.njk
title: Find Creative Strategy Jobs at the best brands
intro: Discover the best jobs from the best agencies and brands in DTC, Ecommerce, and more.
---
<section class="hero">
  <h1>{{ title }}</h1>
  <p class="intro">{{ intro }}</p>
  <div class="hero-actions">
    <a class="button button--dark" href="#jobs">Browse jobs</a>
    <a class="button button--sand" href="/post-a-job/">Post a job</a>
  </div>
</section>

{% set marqueeBrands = collections.brands | marqueeBrands %}
{% if marqueeBrands.length %}
  <section class="logo-marquee" aria-label="Featured brands">
    <div class="logo-marquee__track">
      {% for copy in [1, 2] %}
        <div class="logo-marquee__group"{% if copy == 2 %} aria-hidden="true"{% endif %}>
          {% for brand in marqueeBrands %}
            <div class="logo-marquee__item"{% if brand.data.marquee_width or brand.data.marquee_scale or brand.data.marquee_darken %} style="{% if brand.data.marquee_width %}--marquee-width: {{ brand.data.marquee_width }}px;{% endif %}{% if brand.data.marquee_scale %} --marquee-scale: {{ brand.data.marquee_scale }};{% endif %}{% if brand.data.marquee_darken %} --marquee-filter: grayscale(1) brightness(.25);{% endif %}"{% endif %}>
              <img src="{{ brand.data.logo }}" alt="{{ brand.data.name }}" eleventy:widths="192,384" eleventy:formats="svg,webp" sizes="(max-width: 680px) 120px, 150px">
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </section>
{% endif %}

<section class="newsletter" aria-labelledby="newsletter-title">
  <div class="newsletter__copy">
    <h2 id="newsletter-title">Be the first to know about new jobs</h2>
    <p>Get new job openings delivered to your inbox each week.</p>
  </div>
  <form class="newsletter__form" action="{{ site.newsletter.form_action }}" method="post">
    <label class="visually-hidden" for="newsletter-email">Email address</label>
    <input id="newsletter-email" name="fields[email]" type="email" autocomplete="email" placeholder="Email address" required>
    <button type="submit">
      Sign up for updates
      <img src="/assets/icons/arrow-right.svg" alt="" eleventy:ignore>
    </button>
  </form>
</section>

<section class="jobs" id="jobs" aria-labelledby="jobs-title">
  <div class="section-heading">
    <h2 id="jobs-title">Featured positions</h2>
  </div>

  <div class="job-list">
    {% for job in collections.jobs | featuredJobs %}
      {% set brand = collections.brands | brandBySlug(job.data.brand) %}
      {% include "components/job-card.njk" %}
    {% else %}
      <p>No featured roles have been published yet.</p>
    {% endfor %}
  </div>

  {% if collections.jobs.length %}
    <div class="jobs-more">
      <a class="button button--dark button--browse-jobs" href="/jobs/">
        Browse more jobs
        <img src="/assets/icons/arrow-right.svg" alt="" eleventy:ignore>
      </a>
    </div>
  {% endif %}
</section>
