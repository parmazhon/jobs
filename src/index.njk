---
layout: layouts/base.njk
title: Find Creative Strategy Jobs at the best brands
intro: Discover the best jobs from the best agencies and brands in DTC, Ecommerce, and more.
---
<section class="hero">
  <h1>{{ title }}</h1>
  <p class="intro">{{ intro }}</p>
  <div class="hero-actions">
    <a class="button button--dark" href="#jobs">Browse jobs</a>
    <a class="button button--sand" href="mailto:{{ site.email }}">Post a job</a>
  </div>
</section>

{% set marqueeBrands = collections.brands | marqueeBrands %}
{% if marqueeBrands.length %}
  <section class="logo-marquee" aria-label="Featured brands">
    <div class="logo-marquee__track">
      {% for copy in [1, 2] %}
        <div class="logo-marquee__group"{% if copy == 2 %} aria-hidden="true"{% endif %}>
          {% for brand in marqueeBrands %}
            <div class="logo-marquee__item">
              <img src="{{ brand.data.logo }}" alt="{{ brand.data.name }}" eleventy:ignore>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </section>
{% endif %}

<section class="jobs" id="jobs" aria-labelledby="jobs-title">
  <div class="section-heading">
    <h2 id="jobs-title">Open positions</h2>
  </div>

  <div class="job-list">
    {% for job in collections.jobs %}
      {% set brand = collections.brands | brandBySlug(job.data.brand) %}
      <article class="job-card">
        <div class="job-content">
          <div class="job-overview">
            <h3><a href="{{ job.url }}">{{ job.data.title }}</a></h3>
            <ul class="job-facts" aria-label="Job details">
              <li><img class="fact-icon" src="/assets/icons/map-pin.svg" alt="" eleventy:ignore>{{ job.data.workplace }}</li>
              <li><img class="fact-icon" src="/assets/icons/briefcase.svg" alt="" eleventy:ignore>{{ job.data.employment_type }}</li>
              {% if job.data.salary %}<li><img class="fact-icon" src="/assets/icons/dollar-sign.svg" alt="" eleventy:ignore>{{ job.data.salary }}</li>{% endif %}
            </ul>
          </div>
          <div class="company-row">
            {% if brand %}
              <a class="company-mark" href="{{ brand.url }}" aria-label="View {{ brand.data.name }}" style="--avatar-bg: {{ brand.data.avatar_background or '#ffffff' }}">
                {% set avatarLogo = brand.data.avatar_logo or brand.data.logo %}
                {% if avatarLogo %}<img src="{{ avatarLogo }}" alt="" eleventy:widths="96,192" eleventy:formats="svg,webp" sizes="96px">{% else %}<span class="company-monogram" aria-hidden="true">{{ brand.data.name | first }}</span>{% endif %}
              </a>
            {% else %}
              <span class="company-mark" aria-hidden="true"></span>
            {% endif %}
            <div>
              <p class="company">
                {% if brand %}<a href="{{ brand.url }}">{{ brand.data.name }}</a>{% else %}Brand{% endif %}
              </p>
              <p class="company-detail">{% if brand and brand.data.description %}{{ brand.data.description }}{% else %}Creative company in {{ job.data.location }}{% endif %}</p>
            </div>
          </div>
        </div>
        <a class="learn-more" href="{{ job.url }}">Learn more <img src="/assets/icons/arrow-right.svg" alt="" eleventy:ignore></a>
      </article>
    {% else %}
      <p>No roles have been published yet.</p>
    {% endfor %}
  </div>
</section>
