<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = seo_title or title or name %}
    {% set pageDescription = description or site.description %}
    {% set canonicalUrl = site.url + page.url %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ pageDescription }}">
    <title>{% if seo_title %}{{ seo_title }}{% else %}{{ pageTitle }}{% if pageTitle != site.name %} · {{ site.name }}{% endif %}{% endif %}</title>
    <link rel="canonical" href="{{ canonicalUrl }}">
    <meta property="og:type" content="{% if is_article %}article{% else %}website{% endif %}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    {% if noindex %}<meta name="robots" content="noindex,follow">{% endif %}
    <link rel="stylesheet" href="/assets/css/main.css">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ site.name | jsonString | safe }},
        "url": {{ site.url | jsonString | safe }},
        "description": {{ site.description | jsonString | safe }}
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="site-name" href="/">{{ site.name }}</a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/guides/">Career guides</a>
        <a href="/brands/">Browse brands</a>
        <a class="button button--dark button--small" href="/post-a-job/">Post a job</a>
      </nav>
    </header>
    <main id="main">{{ content | safe }}</main>
    <footer class="site-footer">
      <section class="site-footer__newsletter" aria-labelledby="footer-newsletter-title">
        <div>
          <h2 id="footer-newsletter-title">Fresh creative jobs, weekly.</h2>
          <p>New roles from standout brands and agencies, sent to your inbox.</p>
        </div>
        <form class="footer-newsletter-form" action="{{ site.newsletter.form_action }}" method="post">
          <label class="visually-hidden" for="footer-newsletter-email">Email address</label>
          <input id="footer-newsletter-email" name="fields[email]" type="email" autocomplete="email" placeholder="Email address" required>
          <button type="submit" aria-label="Sign up for job updates">
            Sign up
            <img src="/assets/icons/arrow-right.svg" alt="" eleventy:ignore>
          </button>
        </form>
      </section>
      <div class="site-footer__inner">
        <div>
          <a class="site-name" href="/">{{ site.name }}</a>
          <p>Creative strategy opportunities and practical career resources.</p>
        </div>
        <nav aria-label="Footer navigation">
          <a href="/#jobs">Browse jobs</a>
          <a href="/jobs/remote-creative-strategist-jobs/">Remote jobs</a>
          <a href="/guides/">Career guides</a>
          <a href="/brands/">Browse brands</a>
          <a href="/guides/how-to-hire-a-creative-strategist/">Hiring guide</a>
          <a href="/post-a-job/">Post a job</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
