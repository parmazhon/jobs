---
layout: layouts/base.njk
---
<article class="brand-detail">
  <a class="back-link" href="/">← All jobs</a>
  <header class="brand-header">
    {% set avatarLogo = avatar_logo or logo %}
    {% if avatarLogo %}<img class="brand-logo" src="{{ avatarLogo }}" alt="{{ name }} logo" style="--avatar-bg: {{ avatar_background or '#ffffff' }}" eleventy:widths="96,192" eleventy:formats="svg,webp" sizes="96px">{% endif %}
    <div>
      <h1>{{ name }}</h1>
      {% if description %}<p class="brand-summary">{{ description }}</p>{% endif %}
      <div class="brand-meta">
        {% if headquarters %}<span>{{ headquarters }}</span>{% endif %}
        {% if industry %}<span>{{ industry }}</span>{% endif %}
        {% if website %}<a href="{{ website }}">Visit website ↗</a>{% endif %}
        {% if careers_url %}<a href="{{ careers_url }}">Careers ↗</a>{% endif %}
      </div>
    </div>
  </header>

  {% if content %}<div class="prose">{{ content | safe }}</div>{% endif %}

  {% set brandJobs = collections.jobs | jobsByBrand(page.fileSlug) %}
  <section class="brand-jobs" aria-labelledby="brand-jobs-title">
    <div class="section-heading">
      <h2 id="brand-jobs-title">Open positions</h2>
    </div>
    <div class="job-list">
      {% for job in brandJobs %}
        <article class="job-card">
          <div class="job-content">
            <h3><a href="{{ job.url }}">{{ job.data.title }}</a></h3>
            <ul class="job-facts" aria-label="Job details">
              {% if job.data.location %}<li><img class="fact-icon" src="/assets/icons/map-pin.svg" alt="" eleventy:ignore>{{ job.data.location }}</li>{% endif %}
              {% if job.data.workplace %}<li><img class="fact-icon" src="/assets/icons/monitor.svg" alt="" eleventy:ignore>{{ job.data.workplace }}</li>{% endif %}
              {% if job.data.employment_type %}<li><img class="fact-icon" src="/assets/icons/briefcase.svg" alt="" eleventy:ignore>{{ job.data.employment_type }}</li>{% endif %}
              {% if job.data.salary %}<li><img class="fact-icon" src="/assets/icons/dollar-sign.svg" alt="" eleventy:ignore>{{ job.data.salary }}</li>{% endif %}
            </ul>
          </div>
          <a class="learn-more" href="{{ job.url }}">Learn more <img src="/assets/icons/arrow-right.svg" alt="" eleventy:ignore></a>
        </article>
      {% else %}
        <p>There are no open positions for {{ name }} right now.</p>
      {% endfor %}
    </div>
  </section>
</article>
